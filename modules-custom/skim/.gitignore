# Module Template Module - Git Ignore

# Environment files (if module has any)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs (if module has build step)
dist/
build/

# Dependencies (if module has its own node_modules)
node_modules/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
.cache/
